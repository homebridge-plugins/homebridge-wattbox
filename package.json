{
  "displayName": "WattBox",
  "name": "@homebridge-plugins/homebridge-wattbox",
  "version": "3.2.0",
  "description": "WattBox plugin for Homebridge.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/homebridge-plugins/homebridge-wattbox.git"
  },
  "bugs": {
    "url": "https://github.com/homebridge-plugins/homebridge-wattbox/issues"
  },
  "engines": {
    "homebridge": "^1.8.5 || ^2.0.0 || ^2.0.0-beta.23 || ^2.0.0-alpha.37",
    "node": "^20 || ^22"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "scripts": {
    "check": "npm install && npm outdated",
    "eslint": "eslint src/**.ts --max-warnings=0",
    "eslint-fix": "eslint src/**.ts --max-warnings=0 --fix",
    "prettier": "prettier --check src *.{yaml,json,md}",
    "prettier-fix": "prettier --write src *.{yaml,json,md}",
    "lint": "npm run eslint",
    "lint-fix": "npm run eslint-fix && npm run prettier-fix",
    "fmt": "npm run lint-fix",
    "watch": "npm run build && npm link && nodemon",
    "build": "rm -rf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "npm run eslint"
  },
  "keywords": [
    "homebridge-plugin",
    "wattbox"
  ],
  "dependencies": {
    "async-lock": "^1.4.1",
    "cache-manager": "^6.4.3",
    "cacheable": "^1.10.4",
    "keyv": "^5.5.2",
    "http-parser-js": "^0.5.10",
    "pubsub-js": "^1.9.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.2",
    "@types/cache-manager": "^4.0.6",
    "@types/node": "^24.5.2",
    "@types/pubsub-js": "^1.8.6",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "<8",
    "@typescript-eslint/parser": "<8",
    "eslint": "<9",
    "homebridge": "^1.11.0",
    "homebridge-config-ui-x": "^5.6.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/mocha": "^10.0.10",
    "typescript": "<5.6.0"
  }
}
